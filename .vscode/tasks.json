{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Website: Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--", "--host", "0.0.0.0"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*vike.*",
          "endsPattern": ".*(Local|Network):.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Website: Build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    },
    {
      "label": "Website: Preview",
      "type": "shell",
      "command": "npm",
      "args": ["run", "preview", "--", "--host", "0.0.0.0"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*vike.*",
          "endsPattern": ".*(Local|Network):.*"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}